# --- STUB: design (MAD-X / Xsuite lattice-deck handoff) ---------------------
# Note: (.design, "cern") IS substrate-adjacent to xsuite_optics.py via
# (.synthesize, "cern") but the verbs are different — synthesize emits the
# matched-optics; design produces the lattice template before matching.
# Typed cockpit-consumer record CernDesignRecord exists (R3 decode target);
# substrate script NOT YET AUTHORED → cellrun honest-skips rc=2.
[cell.design]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/cern/design.py
record_kind       = cern_design_record
output_dir        = exports/cern/design
accel_mechanism   = rf_cavity
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "stub — a real impl would emit a MAD-X SEQUENCE deck (or Xsuite line) as a lattice-deck handoff artifact (element defs · drift/quad lengths · strengths) into a typed CernDesignRecord; no substrate script authored yet (cellrun honest-skips rc=2).",
  "domains/cern.md §2 — MAD-X is the de-facto lattice/optics language; design verb naturally emits the SEQUENCE deck BEFORE the synthesize verb does the matching/optimization.",
  "measurement_gate = GATE_OPEN permanently · absorbed=false — an un-matched lattice deck is never an absorption claim (g3).",
]

