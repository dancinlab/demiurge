# matter.demi — verb-cell manifest for the matter (materials) domain
# Demiurge witness: ActionDispatch → CellrunDispatch.run("matter", verb)
#
# UNUSUAL CASE: matter has NO stdlib/matter/ directory in hexa-lang —
# the real SSOT for materials lives in the sibling repo `~/core/hexa-matter/`
# (D17 — hexa-matter owns the materials toolkit, demiurge is consumer
# only). Until a `stdlib/cockpit/cellrun.hexa`-compatible adapter script
# is dropped under `stdlib/matter/<verb>.py` (or a sibling-repo dispatch
# path is generalised into the manifest dialect — see ProducerRegistry+
# Sibling.swift G3+G4 helper for ufo-style sibling cells), every cell in
# this manifest honest-skips via cellrun rc=2 (script missing).
#
# Format: cellrun.hexa Phase A dialect — see firmware.demi header for the
# spec. Script paths are RELATIVE to ~/core/hexa-lang/.
#
# Citations (anchored, not repeated per-cell — see domains/matter/README.md):
#   - hexa-matter sibling repo SSOT (~/core/hexa-matter/) — closure-invariant
#     materials sweep aggregator (verify/run_all.hexa)
#   - D17 g_stdlib_ownership — hexa-matter is OWNER, demiurge is consumer-
#     pointer only
#   - κ-30 / D53 historical precedent: MatterAnalyzer.swift was the FIRST
#     sibling-repo dispatcher in demiurge (commit-pin + per-script gate
#     decisioning); G3+G4 generalised the pattern to siblingRepoVariant
#     in ProducerRegistry
#
# Domain caveat (applies to every cell):
# matter = consumer-pointer only (D17). NO Swift simulation of substrate
# is permitted. Stage 4 absorbed=true gating belongs to hexa-matter's own
# verify/run_all.hexa aggregator + closure-invariants; demiurge witnesses
# the PASS, never upgrades the claim. Every cell defaults GATE_OPEN /
# absorbed=false (g3) until hexa-matter's emitted records carry their
# own absorption verdict + commit pin.

# --- UNWIRED: specify (hexa-matter sibling-only) ----------------------------
# Phase A cellrun.hexa: no stdlib/matter/<verb>.py exists → rc=2 honest-skip.
# Future port: either (a) cellrun.hexa learns a sibling-repo substrate kind
# (current ProducerRegistry+Sibling.swift G3+G4 helper but at hexa-lang
# dispatcher level), or (b) thin Python shims under stdlib/matter/<verb>.py
# that forward to `~/core/hexa-matter/verify/run_all.hexa`.
[cell.specify]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/matter/specify.py
record_kind       = matter_specify_record
output_dir        = exports/matter/specify
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "matter + specify pending — material-requirements.json (mech / thermal / chemical / electronic targets) producer 미작성.",
  "hexa-matter sibling repo IS the SSOT (D17); cellrun rc=2 honest-skip until adapter script lands.",
]

