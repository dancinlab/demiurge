# --- UNWIRED: analyze (legacy MatterAnalyzer.swift sibling-repo dispatch) ---
# Legacy κ-30 / D53 MatterAnalyzer.swift was a sibling-repo dispatcher
# (~/core/hexa-matter/verify/run_all.hexa spawn). D111 Phase C migration
# routes (.analyze, "matter") via CellrunDispatch instead — manifest has
# no stdlib/matter/analyze.py, so honest-skip rc=2. Until either (a) a
# stdlib/matter/analyze.py shim is added that spawns hexa-matter's
# run_all.hexa, or (b) cellrun.hexa is taught a sibling-repo substrate
# kind, this cell is a clear gap (g3 — NEVER silently mark absorbed).
[cell.analyze]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/matter/analyze.py
record_kind       = matter_analyze_record
output_dir        = exports/matter/analyze
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "matter + analyze: legacy MatterAnalyzer.swift κ-30/D53 spawned ~/core/hexa-matter/verify/run_all.hexa (sibling-repo SSOT, D17 owner).",
  "D111 Phase C: legacy bridge removed → cellrun route via stdlib/matter/analyze.py. Adapter script 미작성 → honest-skip rc=2 (g3).",
  "Models/MatterRecord.swift preserved for the day the adapter lands (R3 compliance, typed records stay).",
  "Stage 4 absorbed=true gating belongs to hexa-matter's own aggregator; demiurge witnesses, never upgrades.",
]

