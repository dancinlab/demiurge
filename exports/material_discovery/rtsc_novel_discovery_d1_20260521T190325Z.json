  "finding_summary": {
    "hydride_underprediction_persists": true,
    "note": "H3S, LaH10, YH6, CaH6 all remain 91-97% underpredicted DESPITE accurate Im-3m / Fm-3m CIFs from Drozdov 2015, Somayazulu 2019, Troyan 2021, Ma 2022. CaH6 modest improvement (96.7 → 91.1%, +5.6pp) but pred Tc still 19.1 K vs measured 215 K.",
    "best_d1_improvement": "CaH6 +5.6pp (96.7 → 91.1) due to corrected sodalite Wyckoff positions",
    "worst_d1_regression": "H3S +0.1pp (essentially unchanged: 92.2 → 92.3)",
    "mgh6_predicted_only": "pred Tc 51.5 K; comparison to literature-predicted (Feng 2015) 260 K — predicted material not measured",
    "a15_calibration": "V3Si over-predicted 64% off (28K vs 17K), Nb3Sn under-predicted 50% off (9K vs 18K) — phonon-only model accurate within factor-of-2 only",
    "iron_based_failure": "FeSe pred 1.17 K vs measured 8K bulk · LaFeAsO pred 5.0 K vs measured 26K F-doped — phonon-only model misses unconventional spin-fluctuation pairing (expected)",
    "bismuthate_underprediction": "BaKBiO3 pred 6.3 K vs measured 30 K (79% off) — bipolaron / charge-density-wave physics not captured"
  },
  "breakthrough_assessment": {
    "structure_quality_was_the_issue": false,
    "evidence": "4/4 high-P hydride candidates remain 91-97% underpredicted after publication-grade CIF substitution. CaH6 modest +5.6pp improvement = structure refinement helps but does NOT close the gap. The 92-97% rel_err persists across approximate AND accurate structures.",
    "fundamental_limitation_confirmed": true,
    "rationale": "BETE-NET trained on ambient-pressure SuperCon DB cannot extrapolate to GPa-regime electron-phonon coupling. Structure accuracy is a small-fraction correction (single-digit pp) on top of a ~92% domain-shift error floor.",
    "next_breakthrough_direction": "D2 = pressure-aware ML (input P + V/V0 + lattice strain as conditioning features) OR alchemical DFT-AD fallback for GPa-regime candidates. Structure SSOT (D1) is necessary but not sufficient."
  },
  "scope_caveats": [
    "(s1) BETE-NET CSO prediction is ML inference, NOT measurement. R4 invariant: absorbed=false 영구.",
    "(s2) Hydride structures here are at experimentally-confirmed high-P phase Im-3m / Fm-3m (Drozdov 2015 · Somayazulu 2019 · Troyan 2021 · Ma 2022) — NOT simplified ambient-P approximations.",
    "(s3) Persistent 91-97% rel_err with publication-grade CIFs → BETE-NET ambient-trained limit, NOT structure approximation artifact.",
    "(s4) RTSC.md §8.9 (c) gate (ambient pressure) FAILS for all hydrides regardless of ML prediction.",
    "(s5) Multi-atom calibration band (V3Si, Nb3Sn, BaKBiO3, LaFeAsO, FeSe) shows 50-85% rel_err typical for phonon-only model on conventional + unconventional SC.",
    "(s6) MgH6 measured_tc_K=260 K = LITERATURE-PREDICTED only (Feng 2015), not synthesized. rel_err there is sim-vs-sim.",
    "(s7) BaPbO3 measured_tc_K=0 → pred 6.8 K is a false positive at the low end (model finds spurious coupling).",
    "(s8) BaKBiO3 CIF approximated as ordered Ba/K end-member; real material is disordered Ba0.6K0.4. σ/λ=1.74 surfaces this as OOD."
  ],
