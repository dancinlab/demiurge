#!/usr/bin/env tape
# AGENTS.tape ‚ÄĒ Demiurge project governance (SSOT for load-bearing rules)
# tape v1.2. Decision audit trail = design.md (D1..). This file = the
# enforced governance an agent must obey in this repo.

@V := "tape" :: spec [active]
  version = "1.2"

## INDEX (curated pointer table ‚ÄĒ keep in sync if you add or remove a top-level entry)
# @D g_hexa_only              ‚ÄĒ ULTIMATE FORM = hexa-native; Python/Swift/external CLI/sibling-repo binary are TRANSITIONAL POINTERS, not endpoints; absorbed=true requires hexa-native parity port (D80)
# @D g_no_hardcoded_data      ‚ÄĒ ŽćįžĚīŪĄįŽäĒ declarative SSOT (.demi/.tape/.md/INDEX.*), žĹĒŽďúŽäĒ type + loader; hardcoded list/dict in Swift = violation (D86)
# @D g_demiurge_pointer_only  ‚ÄĒ demiurge = pointer / spawn wrapper ONLY; every producer script lives in hexa-lang/stdlib/  (D61)
# @D g_stdlib_ownership       ‚ÄĒ stdlib/ namespace belongs EXCLUSIVELY to hexa-lang; demiurge is consumer only   (D15)
# @D g3_no_over_claim         ‚ÄĒ never assert unmeasured/unproven results; SKIP-mode regression banned           (D12)
# @D g_clean_room             ‚ÄĒ prior art absorbed from public surface only; no closed-binary RE / DRM bypass   (D1)
# @D g_decouple               ‚ÄĒ hexa-bio + comb + hexa-matter all typed-interface-consumed (decoupled)          (D2+D11)
# @D g_scope                  ‚ÄĒ design-only rescinded; full scope incl. execution/absorption, no-big-bang       (D10+D12)
# @D g_absorption             ‚ÄĒ per absorbed tool: one rfc_0NN, clean-room, measured gate, guarded tombstone    (-)
# @D g_hexa_native            ‚ÄĒ absorb into hexa intrinsics, never shell out (bounded rfc_048 exception)        (D14+D18)
# @D g_swift_native           ‚ÄĒ Swift work prefers SwiftUI/Foundation/AppKit + Apple-canonical patterns first   (D26)
# @D g_cockpit_isolation      ‚ÄĒ cockpit/ logically outside governance boundary; reads exports/docs one-way only (D27+D41)
# @D g_ai_agent_action_surface ‚ÄĒ cockpit/CLI may invoke AI agent as mutation intermediary; agent writes exports (D34)
# @D g_ai_agent_chat_surface  ‚ÄĒ LEFT Chat tab routes to Claude Code API/CLI; honesty-banner on action replies   (D37+D38)
# @D g_cockpit_reinstall      ‚ÄĒ on cockpit/ source change, re-run demiurge install so installed app stays sync  (-)
# @D g_ssot_single_source     ‚ÄĒ one fact / one logic lives in one canonical home; derived docs are pointers     (D50)
# @F forbidden                ‚ÄĒ hard denies f1..f6 (stdlib tree, over-claim, RE, silent-skip, early-tombstone, chat-claim)
# @N ssot                     ‚ÄĒ pointer map: where governance + decisions + arch + progress live
# @N n_cockpit_ar_target      ‚ÄĒ cockpit 3D viewer uses RealityKit to port to AR / visionOS spatial rendering    (D35)
# the entries themselves are SSOT; this index is a derived pointer table per @D g_ssot_single_source / D50.

@D g_hexa_only := "ultimate form = hexa-native" :: governance [required d=2026-05-20 active]
  rule = "every producer / kernel / record schema / verify oracle's ULTIMATE destination is hexa-native (hexa-lang). Python adapters, Swift cockpit, external CLI, sibling-repo binaries are TRANSITIONAL POINTERS ‚ÄĒ bridges, not endpoints. absorbed=true on a measured cell requires the substrate's hexa-native parity port to exist AND match the transitional implementation to a cited tolerance; otherwise GATE caps at GATE_OPEN regardless of how many intermediate checks pass."
  user_directive = "2026-05-20 ‚ÄĒ 'hexa only ¬∑ hexa-native' žĶúžÉĀŽč® ÍłįŽ°Ě"
  general_principle = "transitional substrates are the bridge. Every cell's ultimate honest state is `hexa-native producer ‚áĄ analytic oracle, parity-closed`. Until that lands, GATE_OPEN / absorbed=false stays as a hard cap. This RAISES `g_hexa_native` (D14+D18, absorption-time intrinsics preference) into an absolute endpoint rule ‚ÄĒ not just preference, requirement-for-absorbed."
  examples_compliant = "chip ¬ßB sweep_oracle_parity.hexa (őļ-43 / D70) ‚ÄĒ first DYNAMIC absorbed=true BECAUSE hexa-native. matter+analyze (D17) ‚ÄĒ hexa-lang/hexa-matter substrate is the ultimate form, demiurge consumes as pointer. rfc_006 yosys hexa-native port (in progress) ‚ÄĒ the path."
  examples_pointer_only = "cern+synth őļ-51 flipped on Xsuite ‚áĄ Wiedemann/Lee analytic match ‚ÄĒ scope_caveats explicitly spell out this is ALGORITHM-level closure on a PYTHON SUBSTRATE, not hexa-native closure. The flip is honest at the algorithm layer; the hexa-native FODO twiss kernel does not yet exist. By g_hexa_only this is a PROVISIONAL absorbed=true (subject to demotion if the hexa-native port diverges)."
  enforcement = "Record schema MUST carry `hexa_native_parity: { ref: <kernel path>, rel_err: <number>, tolerance: <number> }` when emitted with absorbed=true. Records without this field cap at GATE_OPEN even if every intermediate check passes. The transitional flip pattern (cern+synth őļ-51) is allowed under scope_caveats but flagged with `hexa_native_parity = null` and `provisional = true`."
  see_also = "g_hexa_native (D14+D18, absorption-preference RAISED to endpoint by this rule); g3_no_over_claim (D12); D72 kernel layer (the path); D80 (this decision in design.md audit)"
  decision_ref = "design.md D80"

@D g_no_hardcoded_data := "ŽćįžĚīŪĄįŽäĒ declarative SSOT, žĹĒŽďúŽäĒ type + loader" :: governance [required d=2026-05-20 active]
  rule = "Any list, dict, table, or record that represents *data* MUST live in a declarative SSOT file (`.demi`, `.tape`, `.md` body, `INDEX.*`) ‚ÄĒ NOT in Swift hardcoded literal arrays / dicts / case lookup tables. The Swift side carries (a) the *type* schema, (b) the *loader* parsing the SSOT, and (c) a thin polyfill / dev-fallback only when the SSOT file is genuinely missing (first launch, embedded test rig). Hardcoded data in Swift code is a governance violation."
  user_directive = "2026-05-20 ‚ÄĒ 'ŪēėŽďúžĹĒŽĒ© ÍłąžßÄ' (after D85 PRODUCERS.demi ž†úžēą žčúž†ź)"
  general_principle = "Ž™®Žď† ŽćįžĚīŪĄįŽäĒ SSOT Ūēú Í≥≥, žĹĒŽďúŽäĒ Í∑ł SSOT Ž•ľ parse ŪēėŽäĒ framework. žÉą ŽŹĄŽ©ĒžĚł / žÉą producer / žÉą falsifier / žÉą cell ž∂ĒÍįÄŽäĒ declarative file Ūēú ž§Ą (.demi ŽėźŽäĒ ŽĻĄžä∑). Swift žĹĒŽďú Ž≥ÄÍ≤Ĺ 0. žĚīÍĪī D50 g_ssot_single_source žĚė *code-vs-data* žł° ÍįēŪôĒ ‚ÄĒ D50 žĚī 'Ūēú žā¨žč§ Ūēú Í≥≥' žĚīÍ≥† g_no_hardcoded_data ÍįÄ 'Í∑ł Ūēú Í≥≥žĚÄ žĹĒŽďú žēĄŽčĆ ŽćįžĚīŪĄį' žěĄžĚĄ Ž™Öžčú."
  examples_compliant = "domains/INDEX.demi (D83) ‚ÄĒ DomainCatalog.all ÍįÄ runtime-load + dev-fallback (allHardcoded ŽäĒ polyfill). domains/PRODUCERS.demi (D85, in-progress) ‚ÄĒ ProducerRegistry sibling-cells declarative SSOT. AGENTS.tape žěźž≤ī ‚ÄĒ governance ŽćįžĚīŪĄįÍįÄ .tape declarative."
  examples_violation = "ProducerRegistry.entries žóź hardcoded `[ProducerCellKey: ProducerEntry]` literal žĚė sibling-repo cells (cern/analyze žĚė pylhe / xsuite-tracking žĚÄ *žėąžôł* ‚ÄĒ Swift function reference ŽĚľ declarative Ž∂ąÍįÄŽä•). DomainCatalog.allHardcoded žĚė 19 entries ‚ÄĒ INDEX.demi žĚė polyfill Ž°úŽßĆ žú†žßÄ, prod path ŽäĒ SSOT žöįžĄ†."
  enforcement = "PR review checklist: any new `static let` Swift array / dict that represents *data* (not config / not constants) = block. Refactor into .demi + Loader pattern. Hardcoded fallback žĚÄ SSOT-missing-only path Ž°ú Ž™Öžčú (`loadAllOrFallback`)."
  exception = "Swift function references (e.g., `CernAnalyzeXsuiteProducer.runAnalyze`) ‚ÄĒ Swift cannot reflect function bodies from .demi at runtime, so Swift-class variants stay coded. The .demi side only handles *external* dispatchable substrates (sibling-repo binaries, hexa scripts, Python adapters). When a Swift function reference is genuinely needed, the registry merges hardcoded Swift entries + loaded .demi entries (additive, not replacement)."
  see_also = "g_hexa_only (D80) ¬∑ g_ssot_single_source (D50) ¬∑ D83 .demi format ¬∑ D85 PRODUCERS.demi"
  decision_ref = "design.md D86"

@D g_demiurge_pointer_only := "demiurge = pointer / spawn wrapper ONLY" :: governance [required d=2026-05-20 active]
  rule = "demiurge is a pointer / spawn-wrapper ONLY for every external-tool producer script (Python / shell / hexa-native). The script SSOT lives in `hexa-lang/stdlib/<domain>/`, NEVER in `demiurge/`. demiurge's Swift `*Producer.swift` files only `Process`-spawn the hexa-lang-owned script; they hold no compute logic."
  demiurge_role = "spawn wrapper + typed Record decoder. NEVER author or own a producer script. NEVER carry `cockpit/scripts/*.py` (generalizes g_stdlib_ownership from hexa-native wrappers to ALL producer scripts including Python/shell)."
  user_directive = "2026-05-20 ‚ÄĒ 'AGENTS.tape žĶúžÉĀŽč®žúľŽ°ú ŪēīŽčĻŽāīžö© žėģÍ≤®žĄú ÍłįŽ°Ě, demiurge ŽäĒ ŪŹ¨žĚłŪĄį (spawn wrapper)'. Generalizes D15/g_stdlib_ownership to producer-side scripts (Python ngspice/pvlib/skyfield/urdfpy/networkx/freecad wrappers etc.) ‚ÄĒ not only hexa-native modules."
  examples_correct = "`MatterAnalyzer.swift` spawns `hexa run ~/core/hexa-matter/verify/run_all.hexa` ‚ÄĒ hexa-lang owns the script. Future `SSCBProducer.swift` correctly spawns `~/core/hexa-lang/stdlib/sscb/ngspice.py`."
  examples_violated_at_birth_must_migrate = "`cockpit/scripts/bipv_freecad.py` (őļ-33) ¬∑ `sscb_ngspice.py` (őļ-34) ¬∑ `grid_networkx.py` / `bot_urdf.py` / `energy_pvlib.py` / `space_skyfield.py` (őļ-35..őļ-39 in-flight) ‚ÄĒ all violations; migration round moves each to `hexa-lang/stdlib/<domain>/`, updates demiurge Producer.swift spawn path."
  enforcement = "every new producer's PR must show the script lives under `~/core/hexa-lang/stdlib/<domain>/` and demiurge carries only a `*Producer.swift` `Process` spawn wrapper. Any `cockpit/scripts/*.py` = automatic block."
  see_also = "D15 (stdlib ‚äā hexa-lang) ¬∑ D17 (matter parity precedent: SSOT=hexa-lang, demiurge=consumer-pointer) ¬∑ D61 (this decision, design.md) ¬∑ ABSORPTION.md ‚Ď† STDLIB"

@D g_stdlib_ownership := "stdlib ‚äā hexa-lang ONLY" :: governance [required d=2026-05-18 active]
  rule = "The `stdlib/` namespace belongs EXCLUSIVELY to hexa-lang. demiurge is a *consumer* of hexa-lang stdlib ‚ÄĒ it MUST NOT own or carry a `stdlib/` tree."
  demiurge_role = "ÍįÄž†łŽč§ žďįŽäĒ ž™Ĺ (consumer). Absorbed/re-derived reusable hexa-native modules belong in hexa-lang/stdlib/ (rfc_047/048 precedent), referenced from demiurge."
  user_directive = "2026-05-18 ‚ÄĒ 'stdlib žĚÄ žė§Ž°úžßÄ hexa-lang žĚī Ž≥īžú† ¬∑ demiurge ŽäĒ ÍįÄž†łŽč§žďłŽ∂Ą' ¬∑ 2026-05-19 REAFFIRMED ‚ÄĒ 'hexa-lang = SSOT, demiurge = pointer; Ž™®Žď† stdlib ŽäĒ hexa-lang žÜĆžú†' ¬∑ 2026-05-19 ÍįēŪôĒ ‚ÄĒ 'hexa-lang žĚī žú†žĚľ SSOT: žě¨žā¨žö© ÍįÄŽä•Ūēú stdlib ¬∑ ŽŹĄÍĶ¨ ¬∑ ŪĚ°žąėŽäĒ ž†ĄŽ∂Ä hexa-lang žÜĆžú†; demiurge ŽäĒ ŽŹĄŽ©ĒžĚł žĄ§Í≥Ą ÍłįŪöć ¬∑ žÜĆŽĻĄŽßĆ' ¬∑ 2026-05-19 ž†ēž†ē ‚ÄĒ '~/core/hexa-<id> sibling repo ŪĆ®ŪĄīžĚÄ ŪŹźÍłį; Ž™®Žď† ŽŹĄŽ©ĒžĚłžĚė stdlib ¬∑ ŽŹĄÍĶ¨ŽäĒ hexa-lang žēą (žėą: hexa-lang/component, hexa-lang/stdlib/booksim) ‚ÄĒ Ž≥ĄŽŹĄ sibling repo ÍįÄ SSOT ÍįÄ žēĄŽčė'"
  general_principle = "hexa-lang is the SSOT of ALL stdlib AND every reusable absorbed module. demiurge is a consumer / pointer ONLY ‚ÄĒ it references the SSOT, never owns it. This generalizes beyond `stdlib/`: any reusable hexa-native module re-derived during an absorption (rfc_003/006 pattern) lands in hexa-lang, and demiurge carries a typed-interface pointer (the D17 hexa-matter precedent ‚ÄĒ SSOT=hexa-lang, demiurge=consumer-pointer)."
  kernel_layer = "D72 (2026-05-20): hexa-lang/stdlib/ is 2-layer ‚ÄĒ ‚Ď†a `kernels/<kernel>/` (domain-agnostic reusable math/physics engines: fem ¬∑ mc_transport ¬∑ circuit ¬∑ graph ¬∑ orbital ¬∑ wave_optics ¬∑ cfd ¬∑ logic_synth ¬∑ noc_sim ¬∑ ode_pde) + ‚Ď†b `<domain>/` (thin adapter ‚ÄĒ kernel call + domain params/geometry only). ABSORPTION RULE: when absorbing an external tool, classify WHICH kernel it belongs to FIRST; a new domain MUST reuse an existing kernel before a new kernel is added (a new kernel only for genuinely new math). Prevents N√óM producer explosion ‚Üí N+M. SSOT = design.md D72; see ABSORPTION.md ‚Ď†."
  violation_resolved = "design.md D15 applied 2026-05-18: the 6 modules + .stubs migrated to hexa-lang/stdlib/booksim/ (committed hexa-lang d5a63a82, self-tests re-verified GREEN there); 2026-05-19 ‚ÄĒ d5a63a82 PUSHED to origin/rfc043-hexa-torch (verified via git branch -r --contains). demiurge/stdlib/ git-rm'd. demiurge now carries NO stdlib/ tree ‚ÄĒ rule satisfied. rfc_003 references the hexa-lang location. (Yosys ¬ß4 modules in hexa-lang/stdlib/yosys/ are still .hexa.stub only ‚ÄĒ impl pending a hexa-lang session, NEXT_SESSIONS P-‚Ď°‚ĎĘ.)"

@D g3_no_over_claim := "no-over-claim ‚ÄĒ RETAINED" :: governance [required d=2026-05-18 active]
  rule = "Never assert unmeasured/unproven results. 'absorbed'/'parity'/'resolved' only at a measured gate, filed with cited numbers. SKIP-mode regression banned."
  status = "User requested g3 removal (2026-05-18) ‚ÄĒ DECLINED (honesty floor, inherited from user identity SSOT). RETAINED per design.md D12."

@D g_clean_room := "public-surface clean-room (D1)" :: governance [required d=2026-05-18 active]
  rule = "External prior art absorbed from public surface only (OSS/arxiv/patents/standards/datasheets/vendor public docs). No closed-binary RE, no license/DRM circumvention."

@D g_decouple := "typed-interface decoupling (D2/D11)" :: governance [d=2026-05-18 active]
  rule = "hexa-bio + comb + hexa-matter ALL typed-interface-consumed (decoupled). hexa-matter's absorption SSOT = hexa-lang (already žôĄž†Ą žĚīÍīÄ; D17 supersedes the D12 demiurge-absorb ‚ÄĒ domains/matter/ is a pointer, not a copy). comb SSOT stays hexa-lang; archive/comb = non-SSOT mirror."

@D g_scope := "scope (D10 rescinded ‚Üí full)" :: governance [d=2026-05-18 active]
  rule = "design-only (D10) RESCINDED per user (D12) ‚ÄĒ full scope incl. execution/absorption. Still: no-big-bang incremental, hexa-first."

@D g_absorption := "absorption pattern" :: governance [d=2026-05-18 active]
  rule = "Per absorbed tool/repo: one proposals/rfc_0NN_*.md (rfc_047/048 mirror). Clean-room, measured gate, tombstone (archive_ rename + local delete) ONLY after measured-GREEN + dependents + explicit per-step go. Anti-data-loss: push origin before any delete."

@D g_hexa_native := "hexa-native-only (g5)" :: governance [d=2026-05-18 active]
  rule = "Absorb into hexa intrinsics, never shell out ‚ÄĒ EXCEPT the rfc_048-precedented bounded exception: verbatim-preserved foreign substrate invoked as a documented subprocess, fail-loud. Re-derivation to hexa-native is the scheduled follow-on. Precedents (cited): D14 (hexa-matter python shim, now moot per D17), D18 (Yosys flow re-derived hexa-native + ABC tech-mapping invoked as bounded subprocess; rfc_006 ¬ß7)."

@D g_swift_native := "swift = native + canonical patterns first" :: governance [required d=2026-05-19 active]
  rule = "When implementing Swift (rfc_009 macOS cockpit, D22 downstream ‚ÄĒ and any future Swift inside Demiurge's product-surface boundary): prefer SwiftUI / Foundation / AppKit native idioms and Apple-canonical patterns FIRST. Third-party libraries, custom DSLs, or non-canonical structures require an explicit justification noted in the producing PR ‚ÄĒ they are NOT default."
  reason = "rfc_009 cockpit is the product surface for honesty-as-feature (D22, g3); applying g5's hexa-native spirit to the Swift dialect = prefer Apple-canonical Swift idiom over bespoke abstractions. Reduces review surface, keeps build/runtime obvious, aligns with rfc_009 ¬ß5's g5-unpressured boundary, and matches the andrej-karpathy minimum-new-structure principle."
  applies_to = "rfc_009 cockpit (planned build, D22 downstream session) + any future Swift inside Demiurge's product-surface boundary; precedent reusable for other native-dialect product surfaces if they appear."
  user_directive = "2026-05-19 ‚ÄĒ 'swift žěĎžĄĪžčú ÍĶ¨ŪėĄžčú native, canonical Žį©žčĚ žöįžĄ† => AGENTS.tape ŽďĪŽ°Ě'"
  decision_ref = "design.md D26"

@D g_cockpit_isolation := "cockpit/ logical-boundary isolation (D27 + D41)" :: governance [required d=2026-05-19 active]
  rule = "The Swift cockpit lives in `cockpit/` (monorepo, D27) but is logically OUTSIDE Demiurge's governance boundary per rfc_009 ¬ß5. Enforcement: (a-records) cockpit/CLI code reads RECORDS ONLY from `../exports/**` (typed records ‚ÄĒ D2 typed-interface contract); runtime-checked by `RecordLoader.load(url:)` returning `pathOutsideExports` for any URL outside `RecordLoader.exportsRoot`. (a-docs) cockpit/CLI MAY additionally read project metadata documents READ-ONLY (`../design.md`, `../proposals/`, `../domains/`, `../inbox/`, `../archive/`, `../README.md`, `../CHARTER.md`, `../HANDOFF.md`, `../GOAL.md`, `../PLAN.md`, `../ARCH.tape`, `../AGENTS.tape`, `../cockpit/references/`) for sidebar navigation + inspector context (D41); these reads NEVER inform a `measurement_gate` / `absorbed` / `parity` claim. (b) cockpit code MUST NOT import or invoke `hexa-lang/stdlib/*` nor any demiurge hexa-native module. (c) cockpit build artifacts (`.build/`, `DerivedData/`, `*.xcodeproj/xcuserdata/`, `.swiftpm/`) MUST stay in `.gitignore` ‚ÄĒ never enter records SSOT. (d) edit-direction is one-way: cockpit reads exports + reads navigation docs, neither exports nor docs ever read cockpit. (e) the cockpit MAY write its OWN app-state ‚ÄĒ project manifests, settings (rfc_012 workbench, D45) ‚ÄĒ under `~/Library/Application Support/lab.dancin.demiurge/`; this is macOS app-data, NOT `exports/` and NOT a record, so the records-honesty boundary is untouched. Project-produced records still go to `exports/` via the AI agent (@D g_ai_agent_action_surface), never written by the cockpit directly."
  reason = "rfc_009 ¬ß5 architecture diagram draws a governance boundary so g5 (hexa-native-only) stays unpressured. D27 picks monorepo placement (B) ‚ÄĒ the boundary becomes **logical** (consumption-direction + no-import + .gitignore) rather than **physical** (separate repo). This rule makes the logical boundary auditable: any PR that violates (a)/(b)/(c)/(d) is rejected on the same grounds a separate-repo violation would be."
  applies_to = "every commit landing in `cockpit/` subdir + every PR touching the exports/cockpit boundary"
  decision_ref = "design.md D27 (monorepo placement) ¬∑ rfc_009 ¬ß5 (boundary semantics) ¬∑ D2 (typed-interface decoupling) ¬∑ D26 (g_swift_native sister rule)"
  enforcement_check = "pre-commit grep: `grep -rE 'import.*hexa|import.*stdlib' cockpit/` MUST return 0 matches; CI smoke: `git ls-files cockpit/ | xargs grep -l 'exports/' | head` shows consumer paths read from `exports/` only."

@D g_ai_agent_action_surface := "cockpit/CLI may invoke AI agent for actual work" :: governance [required d=2026-05-19 active]
  rule = "cockpit GUI's LEFT Chat tab AND demiurge CLI may invoke an AI agent (D38: Claude Code CLI + API) to perform actual synthesis / measurement / analysis / verification. The agent acts as a producer (D7) ‚ÄĒ it executes engine tools (Yosys / OpenROAD / hexa-matter / Elmer / openEMS / ‚Ä¶) and writes new records to `../exports/**`. The cockpit GUI / CLI itself NEVER mutates `exports/` directly; @D g_cockpit_isolation (d) remains intact."
  reason = "Read-only cockpit (rfc_009 ¬ß5) is correct for the user-facing surface, but the user (2026-05-19) requires real engineering work triggerable from the same surface. Inserting an AI agent as the mutation intermediary preserves: (a) cockpit_isolation (d) edit-direction one-way; (b) D7 producer-owned exports; (c) g3 measured-gate-bound discipline ‚ÄĒ agent actions emit records that carry full provenance/gate/citations."
  applies_to = "any cockpit toolbar action / CLI subcommand / LEFT Chat tab message that initiates work beyond pure display"
  user_directive = "2026-05-19 ‚ÄĒ 'žč§ž†ú Ūē©žĄĪ ŽďĪ žó¨ÍłįžĄú žßĄŪĖČŪē†žąė žěąŽäĒÍĪįžēľ???? cli ŽŹĄ Ūē®ÍĽė ŽßĆŽď§žěź, ai agent žĚīžö©ŪēīžĄú, žěĎžóÖŽŹĄ ÍįÄŽä•ŪēėÍ≤Ć, AGENTS.tape žóźŽŹĄ ÍłįŽ°Ě'"
  decision_ref = "design.md D34"

@D g_ai_agent_chat_surface := "cockpit LEFT Chat tab via Claude Code CLI + API" :: governance [required d=2026-05-19 active]
  rule = "cockpit's LEFT sidebar 1st tab (Chat, D37) routes user messages through an intent classifier to either Claude Code API (conversational, streaming, low-latency Q&A on existing records / citations / caveats) or Claude Code CLI (action-bearing, subprocess with tool-permissions, long-running synth/measure/verify). All action results MUST render their full provenance / measurement_gate / atlas_cite_block / scope_caveats VERBATIM in the chat reply (honesty-as-feature applied to chat ‚ÄĒ rfc_009 ¬ß4); replies that assert measurement/parity/absorption without a backing record render a red REJECTED banner (the @F f2 / f4 mirror in chat)."
  reason = "User (2026-05-19) wants in-cockpit conversational + action capability ('Ž†ąžĚīžēĄžõÉ žēąžóź AI ŽĆÄŪôĒŪėē žßĄŪĖČŽŹĄ ÍįÄŽä•ŪēīžēľŪēī / LLM ŽĆÄŪôĒŪėē / claude code cli & claude code api'). Dual dispatch (API for Q&A, CLI for action) matches the two natural modalities. Honesty-banner-in-chat is the contract that keeps g3 alive when the AI is the surface."
  applies_to = "all input through the cockpit LEFT Chat tab (D37)"
  dispatch = "v0: slash-command heuristic (/synth /measure /verify /analyze -> CLI; otherwise -> API). Phase őĻ: LLM-based intent classifier with explicit dispatch reasoning logged in chat."
  decision_ref = "design.md D37 (location) ¬∑ D38 (backend) ¬∑ D39 (RIGHT inspector for verbatim provenance display)"

@D g_cockpit_reinstall := "cockpit edit ‚Üí hx-install reinstall" :: governance [required d=2026-05-19 active]
  rule = "Whenever cockpit/ source changes land (commit), re-run the install ‚ÄĒ `demiurge install` (= `bash cockpit/install.sh`: release build ‚Üí app-icon ‚Üí .app reassembly ‚Üí /Applications/demiurge.app) ‚ÄĒ so the installed app stays in sync with the repo. The agent runs this as the last step of any cockpit-touching change set, before reporting done."
  reason = "The cockpit is hx-installed as /Applications/demiurge.app (a copied release binary, NOT a live `swift run`). Without a reinstall, the installed app silently lags the repo ‚ÄĒ the user would be running stale code. Re-running install keeps measured-green build == what is installed."
  applies_to = "any commit that modifies cockpit/Sources/** or cockpit/Package.swift or cockpit/install.sh or cockpit/AppIcon/*"
  user_directive = "2026-05-19 ‚ÄĒ 'žąėž†ēžôĄŽ£Ćžčú žóźŽäĒ Ūē≠žÉĀ hx install ŪÜĶŪēīžĄú žě¨žĄ§žĻėŽ•ľ Ūēīž§ė <= AGENTS.tape ŽďĪŽ°Ě'"

@F forbidden := "hard denies" :: governance [required d=2026-05-18 active]
  f1 = "creating/extending a `stdlib/` tree under demiurge (g_stdlib_ownership)"
  f2 = "over-claim ‚ÄĒ asserting unmeasured 'absorbed/parity/resolved' (g3)"
  f3 = "closed-binary RE / license circumvention (g_clean_room)"
  f4 = "silent skip / SKIP-mode regression (g3)"
  f5 = "tombstone (repo rename / local delete) before measured-GREEN + dependents + explicit go"
  f6 = "AI agent chat reply asserting measured outcome without backing record having provenance.measurement_gate ‚ąą {GATE_B_PINNED_MET, GATE_CLOSED_MEASURED} (g_ai_agent_chat_surface; rfc_009 ¬ß4 mirror)"

