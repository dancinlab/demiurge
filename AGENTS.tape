@N n_cockpit_ar_target := "cockpit 3D viewer targets AR / visionOS portability" :: note [d=2026-05-19 active]
  text = "The cockpit's 3D viewer (phase őĻ ‚ÄĒ `ComponentView3D`, the exploded-isometric ComponentMode) uses RealityKit (D35) specifically so it can port to AR / visionOS spatial rendering. RealityKit was picked over SceneKit for exactly this forward path ‚ÄĒ visionOS is RealityKit-native. On macOS the cockpit runs a plain virtual `ARView` viewport with mouse-drag orbit (v0, measured-green); AR / visionOS spatial is the stated future target ‚ÄĒ new platform surfaces reuse the same RealityKit scene graph."
  decision_ref = "design.md D35 ¬∑ rfc_011 ¬ß9"
  user_directive = "2026-05-19 ‚ÄĒ 'AR/visionOS žßÄžõź Ž™©ŪĎúŽ°ú Ūēėžěź AGENTS.tape ÍłįŽ°Ě'"

@N n_cern_producer_alternatives := "cern + analyze carries alternative producers" :: note [d=2026-05-20 active]
  text = "Cell (cern, analyze) is the FIRST cell to use ProducerRegistry (cockpit/Sources/DemiurgeCore/Loaders/ProducerRegistry.swift). Variants: `xsuite-tracking` (default, Xsuite 100-turn FODO tracking ‚ÄĒ real physics, őļ-49 substrate) and `pylhe` (legacy LHE round-trip ‚ÄĒ synthetic, kept for parser-coverage). CLI override: `action analyze cern --producer pylhe`. Other cells stay on the hardcoded ActionDispatch switch ‚ÄĒ registry is additive, joined only when a cell actually carries alternatives. Same-shape Record decode TBD per consumer."
  default_producer = "xsuite-tracking ‚ÄĒ promotes the őļ-49 substrate (real Xsuite particle tracking) over the legacy pylhe round-trip toy, per user gate 2026-05-20."
  decision_ref = "design.md D74 ¬∑ inbox/notes/cern_analyze_producer_alternative_decision_2026-05-20.md"
  user_directive = "2026-05-20 ‚ÄĒ 'Option C ‚ÄĒ ProducerRegistry; defaults Q2 xsuite-tracking, Q3 CLI-only, Q4 governance line YES'"
